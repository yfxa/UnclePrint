generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          String    @default("customer") // "customer" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  status          String          @default("uploaded") // uploaded | preparing | printing | printed | shipping | delivered
  fileName        String
  fileUrl         String
  fileSize        Int             // bytes
  notes           String?
  estimatedPrice  Float?
  finalPrice      Float?
  trackingNumber  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  settings        OrderSettings?
  statusHistory   StatusHistory[]
}

model OrderSettings {
  id            String  @id @default(cuid())
  orderId       String  @unique
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printerModel  String  @default("Bambu Lab X1C")
  material      String  @default("PLA")
  nozzleSize    String  @default("0.4mm")
  layerHeight   String  @default("0.2mm")
  infillPercent Int     @default(15)
  color         String  @default("White")
  quantity      Int     @default(1)
}

model StatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdAt DateTime @default(now())
}
